{
  "name": "cliparr",
  "private": true,
  "description": "Personal media clipper for Plex, Jellyfin, and local video files, featuring a React frontend and Express server.",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#plex/*.mjs": "./scripts/plex/*.mjs",
    "#release/*.mjs": "./scripts/release/*.mjs"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/techsquidtv/cliparr.git"
  },
  "bugs": {
    "url": "https://github.com/techsquidtv/cliparr/issues"
  },
  "homepage": "https://github.com/techsquidtv/cliparr#readme",
  "scripts": {
    "dev": "concurrently -k -s first --handle-input -c \"cyan,magenta\" -n \"frontend,server\" \"pnpm --filter @cliparr/frontend dev\" \"pnpm --filter @cliparr/server dev\"",
    "dev:web": "pnpm --filter @cliparr/www dev --host 127.0.0.1 --port 4321",
    "dev:docker": "concurrently -k -s first --handle-input -c \"cyan,magenta\" -n \"frontend,server\" \"pnpm --filter @cliparr/frontend dev --host 0.0.0.0\" \"pnpm --filter @cliparr/server dev\"",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml build cliparr",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up",
    "build": "pnpm -r build",
    "build:web": "pnpm docs:check && pnpm --filter @cliparr/www build",
    "lint": "pnpm lint:eslint && pnpm lint:types",
    "lint:eslint": "pnpm lint:eslint:root && pnpm -r --if-present lint:eslint",
    "lint:eslint:root": "pnpm exec eslint \"eslint.config.js\" \"scripts/**/*.mjs\"",
    "lint:types": "pnpm -r --if-present lint:types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "plex:sdk:update": "node scripts/plex/update-sdk.mjs",
    "plex:sdk:check": "node scripts/plex/check-sdk.mjs",
    "preflight": "pnpm format:check && pnpm lint && pnpm knip && pnpm test",
    "test": "pnpm plex:sdk:check && pnpm test:release && pnpm test:plex-sdk && pnpm --filter @cliparr/server test && pnpm --filter @cliparr/frontend test",
    "test:release": "node --test scripts/release/*.test.mjs",
    "test:plex-sdk": "node --test scripts/plex/*.test.mjs",
    "release:plan": "node scripts/release/plan-release.mjs",
    "knip": "knip",
    "docs:sync": "pnpm --filter @cliparr/www docs:sync",
    "docs:check": "pnpm --filter @cliparr/www docs:check",
    "cf:deploy": "wrangler deploy",
    "cf:upload-version": "wrangler versions upload",
    "deploy:web": "pnpm build:web && pnpm cf:deploy",
    "preview": "pnpm --filter @cliparr/server preview",
    "start": "pnpm --filter @cliparr/server start",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "~0.97.3",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "knip": "6.14.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "wrangler": "^4.95.0"
  }
}
