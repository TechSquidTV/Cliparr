{
  "name": "@cliparr/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch-path=./src --import tsx ./src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "preview": "NODE_ENV=production tsx src/server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
  }
}
