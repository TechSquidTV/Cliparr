---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import DocsLayout from "@/components/DocsLayout.astro";

type DocsEntry = CollectionEntry<"docs">;

const docs = ((await getCollection("docs")) as DocsEntry[]).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<DocsLayout
  title="Cliparr docs"
  description="Small, practical guides for installing, configuring, and using Cliparr."
  currentSlug=""
>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      docs.map((entry) => (
        <a
          class="focus-ring rounded-lg border border-border bg-card p-5 no-underline transition-colors hover:bg-accent hover:no-underline"
          href={`/docs/${entry.id}`}
        >
          <h2 class="mt-0 border-0 p-0 text-lg font-semibold">
            {entry.data.title}
          </h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            {entry.data.description}
          </p>
        </a>
      ))
    }
  </div>
</DocsLayout>
