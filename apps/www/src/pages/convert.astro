---
import BaseLayout from "@/components/BaseLayout.astro";
import { ConvertTool } from "@/components/convert/ConvertTool";

const description =
  "Convert local video files to MP4, WebM, MOV, MKV, or GIF entirely in your browser. Convert MP4 to WebM, remux MKV to MP4, and export without uploads, ads, or watermarks.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I convert MP4 to WebM?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Upload an MP4, choose WebM as the output format, adjust quality and resolution, then convert directly in your browser.",
      },
    },
    {
      "@type": "Question",
      name: "Can I create a GIF from a video?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Upload a video, choose GIF output, tune quality and dimensions, and export locally with no server upload.",
      },
    },
  ],
};
---

<BaseLayout
  title="Convert"
  seoTitle="Convert Video: MP4, WebM, MKV, MOV, and GIF"
  description={description}
  structuredData={structuredData}
>
  <main class="bg-background text-foreground">
    <section class="border-b border-border bg-background">
      <div class="container-page py-8 sm:py-10">
        <div class="max-w-3xl">
          <p class="section-eyebrow">Local browser conversion</p>
          <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-5xl">
            Convert video.
          </h1>
          <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground">
            {description}
          </p>
        </div>

        <div class="mt-7">
          <ConvertTool client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
