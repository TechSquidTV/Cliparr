---
import BaseLayout from "../components/BaseLayout.astro";
import { getChangelogReleases } from "../lib/githubReleases";

const releases = await getChangelogReleases();
const dateFormatter = new Intl.DateTimeFormat("en", {
  dateStyle: "medium",
  timeZone: "UTC",
});
---

<BaseLayout title="Changelog" description="Cliparr release notes mirrored from GitHub Releases.">
  <section class="container-page py-14 sm:py-18">
    <div class="max-w-3xl">
      <p class="section-eyebrow">Changelog</p>
      <h1 class="mt-5 text-4xl font-semibold tracking-normal sm:text-5xl">Release notes</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        New versions, Docker tags, fixes, and upgrade notes from GitHub Releases.
      </p>
    </div>

    <div class="mt-10 space-y-6">
      {releases.map((release) => (
        <article class="rounded-lg border border-border bg-card p-5 sm:p-6">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-2xl font-semibold">
                <a class="focus-ring rounded-md no-underline hover:underline" href={release.url} target="_blank" rel="noreferrer">
                  {release.name}
                </a>
              </h2>
              <p class="mt-2 text-sm text-muted-foreground">
                <time datetime={release.publishedAt.toISOString()}>{dateFormatter.format(release.publishedAt)}</time>
                <span aria-hidden="true"> · </span>
                <span>{release.tagName}</span>
              </p>
            </div>
            {release.prerelease && (
              <span class="w-fit rounded-full border border-secondary/40 bg-secondary/10 px-3 py-1 text-xs font-semibold text-secondary">
                Prerelease
              </span>
            )}
          </div>
          <div class="release-notes mt-6" set:html={release.htmlBody} />
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
