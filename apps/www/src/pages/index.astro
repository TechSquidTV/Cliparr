---
import BaseLayout from "@/components/BaseLayout.astro";
import CommandBlock from "@/components/CommandBlock.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import { Picture } from "astro:assets";
import screenshotImage from "@/assets/screenshot.webp";
import {
  dockerRunCommand,
  productIntro,
  providers,
  site,
} from "@/data/product";
---

<BaseLayout description={productIntro}>
  <section
    class="overflow-hidden border-b border-border bg-background text-foreground"
  >
    <div class="container-page py-8 sm:py-10">
      <div class="mx-auto max-w-4xl text-center">
        <p class="section-eyebrow">Self-hosted video clipping</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-6xl">
          Clip your personal media.
        </h1>
        <p
          class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl"
        >
          {productIntro}
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a
            href="/docs/getting-started"
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-foreground px-6 text-sm font-semibold text-background transition-colors hover:bg-primary"
          >
            Get started
          </a>
          <a
            href={site.githubUrl}
            target="_blank"
            rel="noreferrer"
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-border bg-card px-6 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
          >
            View on GitHub
          </a>
        </div>
        <p class="mt-4 text-sm text-muted-foreground">
          Transcoded locally in your browser.
        </p>
      </div>

      <div class="mx-auto mt-7 max-w-5xl">
        <div
          class="overflow-hidden rounded-lg border border-[#0A0A0A] bg-[#0A0A0A] p-2 shadow-2xl shadow-black/20"
        >
          <div class="border-b border-white/10 px-3 py-2 text-xs text-white/70">
            <span>Cliparr editor</span>
          </div>
          <div
            class="editor-preview relative overflow-hidden rounded-md bg-[#0A0A0A]"
            data-editor-preview
          >
            <Picture
              src={screenshotImage}
              alt="Cliparr editor showing a video preview, playback controls, and timeline clip selection."
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              width={1600}
              height={986}
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 80rem) 1024px, (min-width: 64rem) calc(100vw - 4rem), calc(100vw - 2rem)"
              quality={72}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="block w-full rounded-md"
            />
            <video
              class="editor-preview-video absolute inset-0 h-full w-full rounded-md object-contain"
              muted
              loop
              playsinline
              preload="none"
              aria-hidden="true"
              data-editor-preview-video
            >
              <source data-src="/preview.webm" type="video/webm" />
              <source data-src="/preview.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="bg-background py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">Focused editing</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          The shortest path from playback to shareable clip.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Cliparr keeps the workflow small: find the source, choose the range,
          export the clip.
        </p>
      </div>
      <div class="mt-8">
        <FeatureGrid />
      </div>
    </div>
  </section>

  <section class="border-b border-border bg-background py-16 sm:py-20">
    <div
      class="container-page grid gap-8 lg:grid-cols-[1fr_1.1fr] lg:items-start"
    >
      <div>
        <p class="section-eyebrow">Self-hosted quick start</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          Run Cliparr with one Docker command.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Self-host Cliparr in Docker, keep your sources connected, and make
          clips whenever something worth saving is playing.
        </p>
      </div>
      <CommandBlock code={dockerRunCommand} label="Docker" lang="bash" />
    </div>
  </section>

  <section class="bg-muted/40 py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">Sources</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          Plex, Jellyfin, and local files.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Connect a server source for active playback discovery, or open a video
          directly from your device when you just need a local clip.
        </p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {
          providers.map((provider) => (
            <article class="rounded-lg border border-border bg-card p-6">
              <div class="flex items-center gap-4">
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-border bg-muted p-2.5">
                  <img
                    src={provider.iconPath}
                    alt=""
                    class="provider-logo h-full w-full"
                  />
                </span>
                <h3 class="text-lg font-semibold">{provider.name}</h3>
              </div>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                {provider.setup}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        return;
      }

      document.querySelectorAll("[data-editor-preview]").forEach((preview) => {
        const video = preview.querySelector("[data-editor-preview-video]");

        if (!(video instanceof HTMLVideoElement)) {
          return;
        }

        let hasLoadedSources = false;
        const loadSources = () => {
          if (hasLoadedSources) {
            return;
          }

          video.querySelectorAll("source[data-src]").forEach((source) => {
            const src = source.getAttribute("data-src");

            if (src) {
              source.setAttribute("src", src);
            }
          });

          video.load();
          hasLoadedSources = true;
        };

        let wantsPreview = false;

        const playPreview = async () => {
          wantsPreview = true;
          loadSources();

          try {
            await video.play();
            if (wantsPreview) {
              preview.setAttribute("data-playing", "true");
            }
          } catch {
            preview.removeAttribute("data-playing");
          }
        };

        const stopPreview = () => {
          wantsPreview = false;
          video.pause();

          if (video.readyState > 0) {
            video.currentTime = 0;
          }

          preview.removeAttribute("data-playing");
        };

        video.addEventListener("playing", () => {
          if (wantsPreview) {
            preview.setAttribute("data-playing", "true");
          }
        });
        preview.addEventListener("pointerenter", playPreview);
        preview.addEventListener("pointerleave", stopPreview);
      });
    })();
  </script>
</BaseLayout>
