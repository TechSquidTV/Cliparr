---
import BaseLayout from "@/components/BaseLayout.astro";
import CommandBlock from "@/components/CommandBlock.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import { Picture } from "astro:assets";
import mobilePreviewImage from "@/assets/mobile-pwa-preview.webp";
import screenshotImage from "@/assets/screenshot.webp";
import {
  dockerRunCommandVariants,
  productIntro,
  providers,
  site,
} from "@/data/product";

const faqs = [
  {
    question: "Where does Cliparr process video?",
    answer:
      "Cliparr processes video in the browser. Local files are read directly by the browser; Plex, Jellyfin, and direct media URL sources can route through your self-hosted Cliparr server's media proxy so the browser can preview and export them.",
    links: [
      { href: "/docs/local-videos", label: "Local videos and URLs" },
      { href: "/docs/providers", label: "Plex and Jellyfin providers" },
    ],
  },
  {
    question: "What does the Cliparr server do?",
    answer:
      "The server handles media server authentication, encrypted provider records, active playback discovery, and proxy work for media routes. It helps the browser reach authenticated sources, while editing and export processing run in the browser.",
    links: [
      { href: "/docs/providers", label: "Provider setup" },
      { href: "/docs/configuration", label: "Configuration" },
    ],
  },
  {
    question: "Does Cliparr use FFmpeg?",
    answer:
      "No. Cliparr does not shell out to FFmpeg for exports. Video export uses browser media APIs through Mediabunny, while GIF export uses the @techsquidtv/gifenc package in the browser.",
    links: [
      { href: "/docs/export-settings", label: "Export settings" },
      { href: "https://mediabunny.dev/", label: "Mediabunny" },
      { href: "https://github.com/KyleTryon/gifenc", label: "gifenc" },
    ],
  },
  {
    question: "Does Cliparr work with Plex and Jellyfin?",
    answer:
      "Yes. Cliparr can connect to Plex and Jellyfin providers, discover active playback sessions, open the current media, and start clipping from the playback position.",
    links: [{ href: "/docs/providers", label: "Plex and Jellyfin" }],
  },
  {
    question: "When should I use Cliparr Convert instead?",
    answer:
      "Use Cliparr Convert when you only need whole-file conversion without self-hosting. The hosted converter runs in your browser and is separate from the full Cliparr app for Plex, Jellyfin, local sources, and timeline clipping.",
    links: [{ href: "/convert", label: "Open Cliparr Convert" }],
  },
] as const;

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${site.url}/#faq`,
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<BaseLayout description={productIntro} structuredData={faqStructuredData}>
  <section
    class="overflow-hidden border-b border-border bg-background text-foreground"
  >
    <div class="container-page py-8 sm:py-10">
      <div class="mx-auto max-w-4xl text-center">
        <p class="section-eyebrow">Self-hosted video clipping</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-6xl">
          Clip your personal media.
        </h1>
        <p
          class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl"
        >
          {productIntro}
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a
            href="/docs/getting-started"
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full bg-foreground px-6 text-sm font-semibold text-background transition-colors hover:bg-primary"
          >
            Get started
          </a>
          <a
            href={site.githubUrl}
            target="_blank"
            rel="noreferrer"
            class="focus-ring inline-flex min-h-11 items-center justify-center rounded-full border border-border bg-card px-6 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
          >
            View on GitHub
          </a>
        </div>
        <p class="mt-4 text-sm text-muted-foreground">
          Transcoded locally in your browser.
        </p>
      </div>

      <div class="mx-auto mt-7 max-w-5xl">
        <div
          class="overflow-hidden rounded-lg border border-[#0A0A0A] bg-[#0A0A0A] p-2 shadow-2xl shadow-black/20"
        >
          <div class="border-b border-white/10 px-3 py-2 text-xs text-white/70">
            <span>Cliparr editor</span>
          </div>
          <div
            class="editor-preview relative overflow-hidden rounded-md bg-[#0A0A0A]"
            data-editor-preview
          >
            <Picture
              src={screenshotImage}
              alt="Cliparr editor showing a video preview, playback controls, and timeline clip selection."
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              width={1600}
              height={886}
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 80rem) 1024px, (min-width: 64rem) calc(100vw - 4rem), calc(100vw - 2rem)"
              quality={72}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="block w-full rounded-md"
            />
            <video
              class="editor-preview-video absolute inset-0 h-full w-full rounded-md object-contain"
              muted
              loop
              playsinline
              preload="none"
              aria-hidden="true"
              data-editor-preview-video
            >
              <source data-src="/preview.webm" type="video/webm" />
              <source data-src="/preview.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="bg-background py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">Focused editing</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          The shortest path from playback to shareable clip.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Cliparr keeps the workflow small: find the source, choose the range,
          export the clip.
        </p>
        <p
          class="mx-auto mt-3 max-w-2xl text-sm leading-6 text-muted-foreground [&_a]:font-medium [&_a]:text-foreground [&_a]:underline [&_a]:underline-offset-4"
        >
          Use Cliparr with <a href="/docs/providers">Plex and Jellyfin</a>, open <a
            href="/docs/local-videos">local videos</a
          >, tune
          <a href="/docs/export-settings">export settings</a>, and burn in
          supported <a href="/docs/subtitle-burn-in">subtitles</a> without turning
          your home server into a render box.
        </p>
      </div>
      <div class="mt-8">
        <FeatureGrid />
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-muted/40 py-16 sm:py-20">
    <div
      class="container-page grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,28rem)] lg:items-center"
    >
      <div class="max-w-2xl">
        <p class="section-eyebrow">Mobile PWA</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          A mobile workspace that feels installed.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Open Cliparr from a phone, install it to your home screen, and keep a
          focused clipping workspace close to the media you are already
          watching.
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-3">
          <div class="border-t border-border pt-4">
            <h3 class="text-base font-semibold">Home screen ready</h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              Manifest icons, shortcuts, and standalone display support make the
              app feel at home outside the browser chrome.
            </p>
          </div>
          <div class="border-t border-border pt-4">
            <h3 class="text-base font-semibold">Touch-first controls</h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              Source selection, playback, and export flows stay reachable on a
              small screen without losing the desktop workflow.
            </p>
          </div>
          <div class="border-t border-border pt-4">
            <h3 class="text-base font-semibold">Ready when you come back</h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              Cliparr keeps the main interface quick to reopen, then refreshes
              your media sessions and source details live.
            </p>
          </div>
        </div>
        <a
          href="/docs/browser-support"
          class="focus-ring mt-8 inline-flex min-h-11 items-center justify-center rounded-full border border-border bg-card px-5 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
        >
          Browser support
        </a>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="mobile-phone-preview">
          <div class="editor-preview mobile-phone-screen" data-editor-preview>
            <Picture
              src={mobilePreviewImage}
              alt="Cliparr running in a narrow mobile layout with a dashboard, source controls, and playback actions."
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              width={402}
              height={874}
              widths={[201, 302, 402]}
              sizes="(min-width: 64rem) 22rem, min(78vw, 22rem)"
              quality={72}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
            <video
              class="editor-preview-video absolute inset-0 h-full w-full object-cover"
              muted
              loop
              playsinline
              preload="none"
              aria-hidden="true"
              data-editor-preview-video
            >
              <source data-src="/mobile-pwa-preview.webm" type="video/webm" />
              <source data-src="/mobile-pwa-preview.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border bg-background py-16 sm:py-20">
    <div
      class="container-page grid gap-8 lg:grid-cols-[1fr_1.1fr] lg:items-start"
    >
      <div>
        <p class="section-eyebrow">Self-hosted quick start</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          Run Cliparr with one Docker command.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Self-host Cliparr in Docker, keep your sources connected, and make
          clips whenever something worth saving is playing.
        </p>
      </div>
      <CommandBlock variants={dockerRunCommandVariants} label="Docker" />
    </div>
  </section>

  <section class="bg-muted/40 py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">Sources</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">
          Plex, Jellyfin, and local files.
        </h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          Connect a server source for active playback discovery, or open a video
          directly from your device when you just need a local clip.
        </p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {
          providers.map((provider) => (
            <article class="rounded-lg border border-border bg-card p-6">
              <div class="flex items-center gap-4">
                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-border bg-muted p-2.5">
                  <img
                    src={provider.iconPath}
                    alt=""
                    class="provider-logo h-full w-full"
                  />
                </span>
                <h3 class="text-lg font-semibold">{provider.name}</h3>
              </div>
              <p class="mt-3 text-sm leading-6 text-muted-foreground">
                {provider.setup}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background py-16 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-eyebrow">Questions</p>
        <h2 class="mt-5 text-3xl font-semibold sm:text-5xl">Cliparr basics.</h2>
        <p class="mt-5 text-base leading-7 text-muted-foreground">
          A few quick answers about self-hosting, provider support, browser
          exports, and where Cliparr Convert fits.
        </p>
      </div>
      <div class="mx-auto mt-8 grid max-w-4xl gap-3">
        {
          faqs.map((faq) => (
            <article class="rounded-lg border border-border bg-card p-5 sm:p-6">
              <h3 class="text-base font-semibold text-foreground">
                {faq.question}
              </h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">
                {faq.answer}
              </p>
              <div class="mt-3 flex flex-wrap gap-3 text-sm font-medium">
                {faq.links.map((link) => (
                  <a
                    class="focus-ring rounded-sm text-foreground underline decoration-border underline-offset-4 hover:decoration-primary"
                    href={link.href}
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      link.href.startsWith("http") ? "noreferrer" : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        return;
      }

      document.querySelectorAll("[data-editor-preview]").forEach((preview) => {
        const video = preview.querySelector("[data-editor-preview-video]");

        if (!(video instanceof HTMLVideoElement)) {
          return;
        }

        let hasLoadedSources = false;
        const loadSources = () => {
          if (hasLoadedSources) {
            return;
          }

          video.querySelectorAll("source[data-src]").forEach((source) => {
            const src = source.getAttribute("data-src");

            if (src) {
              source.setAttribute("src", src);
            }
          });

          video.load();
          hasLoadedSources = true;
        };

        let wantsPreview = false;

        const playPreview = async () => {
          wantsPreview = true;
          loadSources();

          try {
            await video.play();
            if (wantsPreview) {
              preview.setAttribute("data-playing", "true");
            }
          } catch {
            preview.removeAttribute("data-playing");
          }
        };

        const stopPreview = () => {
          wantsPreview = false;
          video.pause();

          if (video.readyState > 0) {
            video.currentTime = 0;
          }

          preview.removeAttribute("data-playing");
        };

        video.addEventListener("playing", () => {
          if (wantsPreview) {
            preview.setAttribute("data-playing", "true");
          }
        });
        preview.addEventListener("pointerenter", playPreview);
        preview.addEventListener("pointerleave", stopPreview);
      });
    })();
  </script>
</BaseLayout>
