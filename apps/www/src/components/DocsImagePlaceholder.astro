---
interface Props {
  caption?: string;
  target?: string;
  title: string;
}

const { caption, target, title } = Astro.props;
---

<figure
  class="my-7 overflow-hidden rounded-lg border border-dashed border-border bg-muted/30"
>
  <div
    class="flex min-h-56 flex-col items-center justify-center px-6 py-10 text-center"
  >
    <p class="section-eyebrow">Image placeholder</p>
    <div class="mt-3 max-w-xl text-lg font-semibold text-foreground">
      {title}
    </div>
    {
      target ? (
        <code class="mt-4 rounded-md border border-border bg-background px-2 py-1 font-mono text-xs text-muted-foreground">
          {target}
        </code>
      ) : null
    }
  </div>
  {
    caption ? (
      <figcaption class="border-t border-border bg-background px-4 py-3 text-sm leading-6 text-muted-foreground">
        {caption}
      </figcaption>
    ) : null
  }
</figure>
