{
  "name": "@cliparr/www",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "pnpm lint:eslint && pnpm lint:types",
    "lint:eslint": "cd ../.. && pnpm exec eslint --config config/eslint.config.js \"apps/www/src/**/*.astro\" \"apps/www/src/**/*.{ts,tsx}\" \"apps/www/scripts/**/*.ts\" \"apps/www/astro.config.ts\" \"apps/www/public/**/*.js\"",
    "lint:types": "astro-check && tsc --noEmit --project tsconfig.scripts.json",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "docs:sync": "tsx scripts/sync-readme.ts --write",
    "docs:check": "tsx scripts/sync-readme.ts --check",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@cliparr/frontend": "workspace:*",
    "@fontsource-variable/outfit": "^5.2.8",
    "@mediabunny/aac-encoder": "^1.49.0",
    "@mediabunny/ac3": "^1.49.0",
    "@sentry/astro": "^10.58.0",
    "@tailwindcss/vite": "^4.3.1",
    "@techsquidtv/gifenc": "1.1.0",
    "astro": "^6.4.8",
    "lucide-react": "^1.21.0",
    "mediabunny": "^1.49.0",
    "mermaid": "11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-mermaid": "^3.0.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vite": "^7.3.5"
  }
}
