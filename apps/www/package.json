{
  "name": "@cliparr/www",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "pnpm lint:eslint && pnpm lint:types",
    "lint:eslint": "pnpm exec eslint \"src/**/*.astro\" \"src/**/*.ts\" \"scripts/**/*.ts\" \"astro.config.ts\" \"public/service-worker.js\"",
    "lint:types": "astro-check && tsc --noEmit --project tsconfig.scripts.json",
    "docs:sync": "tsx scripts/sync-readme.ts --write",
    "docs:check": "tsx scripts/sync-readme.ts --check",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "mermaid": "11.15.0",
    "rehype-mermaid": "^3.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vite": "^7.3.3"
  }
}
