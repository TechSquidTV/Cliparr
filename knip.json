{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["."],
  "workspaces": {
    "apps/frontend": {
      "entry": ["src/main.tsx", "vite.config.js"],
      "ignoreBinaries": ["eslint"],
      "project": ["src/**/*.{ts,tsx,css}"],
      "vite": false
    },
    "apps/www": {
      "ignoreBinaries": ["eslint"],
      "ignoreDependencies": ["@fontsource-variable/outfit", "tailwindcss"],
      "ignoreBinaries": ["eslint"],
      "project": ["src/**/*.{astro,mdx,ts}", "scripts/**/*.ts"]
    },
    "apps/server": {
      "drizzle": false,
      "ignoreBinaries": ["eslint"],
      "ignore": ["src/providers/plex/generated/**"],
      "paths": {
        "@/*": ["./src/*"]
      },
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "ignoreBinaries": ["eslint", "tsc"],
      "project": ["src/**/*.{js,ts}"]
    }
  }
}
