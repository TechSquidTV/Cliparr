{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["."],
  "workspaces": {
    "apps/frontend": {
      "ignoreBinaries": ["eslint"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/www": {
      "ignoreDependencies": ["@fontsource-variable/outfit", "tailwindcss"],
      "project": ["src/**/*.{astro,mdx,ts}", "scripts/**/*.ts"]
    },
    "apps/server": {
      "ignoreBinaries": ["eslint"],
      "project": ["src/**/*.ts"]
    }
  }
}
